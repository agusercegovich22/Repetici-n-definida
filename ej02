/*2. Ingresar 20 números enteros. Determinar e informar la cantidad de valores pares del conjunto */

#include <stdio.h>
#include <stdlib.h>


int main(){
    int num, i, pares;
    printf("Ingresar 20 numeros enteros, para determinar cuales de ellos son pares\n");
    for(i=1;i<=20;i++){
        printf("Igresar numero %d: ", i);
        scanf("%d", &num);
        if(num%2 == 0)
            pares++;
    }
    printf("La cantidad de numeros pares de los 20 numeros ingresados fue: %d", pares);
    printf("\n");
    system("pause");
    return 0;
}
