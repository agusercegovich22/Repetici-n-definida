/*6. Confeccionar un programa que exhiba por pantalla una lista, a dos columnas,
 con los primeros 15 números impares
en la primera y los 15 primeros pares en la segunda, incluyendo los títulos.*/

#include <stdio.h>
#include <stdlib.h>


int main(){
    int i;
    printf("Primeros 15 pares y 15 impares\n\n");
    printf("\tPARES\tIMPARES\n");
    for(i=1;i<=30;i+=2)
        printf("\t%4d\t%5d\n",i, i+1);
    printf("\n");
    system("pause");
    return 0;
}
